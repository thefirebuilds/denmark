{
  "manifest_version": 3,
  "name": "Marketplace Exporter",
  "version": "1.1.0",
  "permissions": ["scripting", "activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "http://127.0.0.1:3001/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_title": "Export Marketplace",
    "default_icon": {
      "16": "images/logo.png",
      "32": "images/logo.png",
      "48": "images/logo.png",
      "128": "images/logo.png"
    }
  },
  "icons": {
    "16": "images/logo.png",
    "32": "images/logo.png",
    "48": "images/logo.png",
    "128": "images/logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/marketplace/item/*"],
      "js": ["content_detail.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content_app_bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
