# Denmark2.0 example environment
# Copy this file to .env and replace placeholder values with your own.
# Do not commit a real .env file.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=denmark
PGUSER=postgres
PGPASSWORD=replace-with-local-postgres-password
PGPOOL_MAX=20
PGIDLE_TIMEOUT_MS=30000
PGCONNECT_TIMEOUT_MS=5000
PGKEEPALIVE_INITIAL_DELAY_MS=10000

# Optional connection string for one-off scripts that use DATABASE_URL.
DATABASE_URL=postgres://postgres:replace-with-local-postgres-password@localhost:5432/denmark

# ---------------------------------------------------------------------------
# Frontend / API
# ---------------------------------------------------------------------------
PORT=5000
VITE_API_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:5173
SESSION_SECRET=replace-with-long-random-session-secret
TOKEN_ENCRYPTION_KEY=replace-with-64-char-hex-or-long-random-secret
DENMARK_BRIDGE_SECRET=replace-with-shared-secret-for-android-bridge
AUTH_ENFORCED=false
AUTH_COOKIE_SECURE=false
AUTH_OWNER_EMAILS=owner@example.com

# ---------------------------------------------------------------------------
# Human authentication (OpenID Connect)
# ---------------------------------------------------------------------------
# Set AUTH_ENFORCED=true only when you actually have a working provider config.
# For local development without real login, leave AUTH_ENFORCED=false.
# If OIDC_CLIENT_ID / OIDC_CLIENT_SECRET are omitted, Denmark will fall back to
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET automatically.
OIDC_ENABLED=true
OIDC_PROVIDER_NAME=oidc
OIDC_ISSUER_URL=https://auth.example.com/realms/denmark
OIDC_CLIENT_ID=replace-with-oidc-client-id
OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
OIDC_REDIRECT_URI=http://localhost:5000/api/auth/callback
OIDC_SCOPES=openid profile email

# Simple Google-based practice setup:
# AUTH_ENFORCED=true
# OIDC_PROVIDER_NAME=google
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID can be omitted if GOOGLE_CLIENT_ID is already set
# OIDC_CLIENT_SECRET can be omitted if GOOGLE_CLIENT_SECRET is already set
# OIDC_REDIRECT_URI=http://localhost:5000/api/auth/callback

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_FMV_MODEL=gpt-4.1-mini
OPENAI_FMV_MARKET_LABEL=Austin, Texas, USA

# ---------------------------------------------------------------------------
# Turo inbox ingestion over IMAP
# ---------------------------------------------------------------------------
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=alerts@example.com
IMAP_PASS=replace-with-imap-app-password
IMAP_TARGET_MAILBOXES=INBOX
IMAP_LOOKBACK_HOURS=72
IMAP_INGEST_LIMIT=100
IMAP_CONNECTION_TIMEOUT=90000
IMAP_GREETING_TIMEOUT=30000
IMAP_SOCKET_TIMEOUT=600000

# ---------------------------------------------------------------------------
# Bouncie telemetry
# ---------------------------------------------------------------------------
BOUNCIE_CLIENT_ID=replace-with-bouncie-client-id
BOUNCIE_CLIENT_SECRET=replace-with-bouncie-client-secret
BOUNCIE_AUTH_CODE=replace-with-one-time-auth-code
BOUNCIE_REDIRECT_URI=http://localhost:5000/api/bouncie/callback

# ---------------------------------------------------------------------------
# DIMO telemetry
# ---------------------------------------------------------------------------
DIMO_CLIENT_ID=replace-with-dimo-client-id
DIMO_DOMAIN=replace-with-dimo-domain
DIMO_PRIVATE_KEY=replace-with-dimo-private-key
DIMO_FLEET_JSON=[]
DIMO_RPM_HISTORY_LOOKBACK_MINUTES=10

# ---------------------------------------------------------------------------
# Google Calendar sync
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/integrations/google-calendar/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GOOGLE_OAUTH_ACCESS_TYPE=offline
GOOGLE_OAUTH_PROMPT=consent

# ---------------------------------------------------------------------------
# Teller banking
# ---------------------------------------------------------------------------
TELLER_CERT_BASE64=replace-with-base64-client-cert
TELLER_KEY_BASE64=replace-with-base64-client-key

# Add a Teller access token after linking an account.
# The app stores active Teller tokens in the teller_tokens table.

# ---------------------------------------------------------------------------
# HCTRA / EZ TAG toll sync
# ---------------------------------------------------------------------------
EZTAG_USERNAME=replace-with-eztag-username
EZTAG_PASSWORD=replace-with-eztag-password
EZTAG_USER_AGENT=Mozilla/5.0 Denmark2.0 local dev

# ---------------------------------------------------------------------------
# Optional public availability push
# ---------------------------------------------------------------------------
PUBLIC_AVAILABILITY_INGEST_URL=https://example.com/api/availability
PUBLIC_AVAILABILITY_BEARER_TOKEN=replace-with-public-availability-token
PUBLIC_AVAILABILITY_HMAC_SECRET=replace-with-public-availability-hmac-secret
